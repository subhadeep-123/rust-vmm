{
    "tests": [
        {
            "test_name": "performance",
            "command": "ROOT=$$PWD && cd {crate_path} && pytest -s $(find \"$$ROOT\" -path \"*/integration_tests/test_benchmark.py\")",
            "platform": [
                "x86_64",
                "aarch64"
            ],
            "timeout_in_minutes": 15,
            "if_changed": "event-manager/*",
            "crate_path": "event-manager"
        }
    ]
}
